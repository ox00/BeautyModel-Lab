# ============================================================
# Python
# ============================================================
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
*.egg
dist/
build/
*.whl

# ============================================================
# Virtual Environment (unified .venv at project root)
# ============================================================
.venv/

# ============================================================
# IDE
# ============================================================
.idea/
.vscode/
*.swp
*.swo

# ============================================================
# Environment & Secrets
# ============================================================
# backend/.env contains API keys — excluded from version control
backend/.env

# ============================================================
# MediaCrawler Runtime Data
# ============================================================
# Browser data directory (login sessions, cache)
MediaCrawler-main/**/browser_data/
# Data output directory
MediaCrawler-main/**/data/
# Local SQLite databases
MediaCrawler-main/**/database/sqlite_tables.db

# ============================================================
# Docker volumes
# ============================================================
postgres_data/
redis_data/

# ============================================================
# OS files
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# Logs
# ============================================================
*.log

# ============================================================
# Test / Cache
# ============================================================
.pytest_cache/
.mypy_cache/
.ruff_cache/
htmlcov/
.coverage

# ============================================================
# Node (MediaCrawler WebUI)
# ============================================================
node_modules/
package-lock.json

# ============================================================
# Alembic
# ============================================================
backend/alembic/__pycache__/

# ============================================================
# Misc
# ============================================================
*.tmp
*.bak
