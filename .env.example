# ============================================================
# Multi-Agent Trend Crawling System - Environment Configuration
# ============================================================
# This is the ONLY .env file in the project.
# Path: backend/.env
# Loaded by Pydantic Settings (settings.py -> env_file)
# MediaCrawler subprocess gets DB vars injected via process_manager.py
# ============================================================
# Copy this file to backend/.env and fill in your values:
#   cp .env.example backend/.env
# ============================================================

# PostgreSQL (Docker: host port 5433 -> container port 5432)
# IMPORTANT: Use port 5433 (not 5432) to avoid conflict with local PostgreSQL
DATABASE_URL=postgresql+asyncpg://postgres:123456@localhost:5433/media_crawler
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:123456@localhost:5433/media_crawler
POSTGRES_DB_PORT=5433
POSTGRES_DB_HOST=localhost
POSTGRES_DB_USER=postgres
POSTGRES_DB_PWD=123456
POSTGRES_DB_NAME=media_crawler

# Redis
REDIS_URL=redis://localhost:6379/0

# Celery
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# MediaCrawler (path is auto-calculated in settings.py, override only if needed)
# Default: <project_root>/MediaCrawler-main/MediaCrawler-main
# MEDIACRAWLER_DIR=

# LLM Configuration (for KeywordExpanderAgent + CleaningAgent)
# Supported: 智谱 GLM (bigmodel.cn), OpenAI-compatible APIs
LLM_API_KEY=your-api-key-here
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MODEL=glm-5.1

# Security
ACCOUNT_ENCRYPTION_KEY=change-me-in-production-32bytes!!

# App
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=true
